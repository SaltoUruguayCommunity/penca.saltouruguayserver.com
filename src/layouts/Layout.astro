---
import "../styles/global.css";
import Toaster from "../components/ui/Toast.tsx";
import LiveBox from "../components/LiveBox.tsx";
import { pencas } from "../actions/pencas";
import { getClientIp, isAntelNetwork } from "../lib/visitor-location";

const SITE_NAME = "Penca Mundial 2026";
const DEFAULT_DESC =
  "Pronosticá los partidos del Mundial 2026, acumulá puntos y competí contra otros hinchas en el ranking de SaltoUruguayServer.";

export interface Props {
  title: string;
  description?: string;
  image?: string;
  noIndex?: boolean;
  ogType?: string;
  ignoreLiveBox?: boolean;
}

const {
  title,
  description = DEFAULT_DESC,
  image,
  noIndex = false,
  ogType = "website",
  ignoreLiveBox = false,
} = Astro.props;

const fullTitle = `${title} — ${SITE_NAME}`;
const url = Astro.url.href;
const origin = Astro.url.origin;

const headers = Astro.request.headers;
const clientIp = getClientIp(headers);
const isAntelISP = await isAntelNetwork(clientIp);

const liveResult = await Astro.callAction(pencas.getLiveMatches, null);
const uruguayMatch = !liveResult.error
  ? liveResult.data.find(
      (m) => m.homeTeam?.name === "Uruguay" || m.awayTeam?.name === "Uruguay",
    )
  : null;
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/ico" href="/favicon.ico" />
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:url" content={url} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        "@id": "https://saltouruguayserver.com/#organization",
        name: "SaltoUruguayServer",
        url: "https://saltouruguayserver.com",
        sameAs: [
          "https://instagram.com/saltouruguayserver",
          "https://discord.gg/XwHSRRwnzS",
          "https://twitch.tv/saltouruguayserver",
          "https://x.com/SaltoUruguayS",
          "https://github.com/yanquisalexander/saltouruguay-web",
        ],
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": `${origin}/#website`,
        url: origin,
        name: SITE_NAME,
        description: description,
        publisher: { "@id": "https://saltouruguayserver.com/#organization" },
        inLanguage: "es-UY",
      })}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,800;0,900;1,800;1,900&family=Inter:wght@400;500;600;700&family=Teko:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen antialiased">
    <slot />
    <Toaster client:load />
    {
      !!uruguayMatch && !ignoreLiveBox ? (
        <LiveBox
          client:load
          isUruguayPlaying={true}
          isAntelISP={isAntelISP}
          homeTeam={uruguayMatch.homeTeam?.name}
          awayTeam={uruguayMatch.awayTeam?.name}
        />
      ) : null
    }
  </body>
</html>

<script>
  document.addEventListener("DOMContentLoaded", async () => {
    const { format } = await import("date-fns");
    const { es } = await import("date-fns/locale");
    for (const el of document.querySelectorAll("[data-time]")) {
      const utc = el.getAttribute("data-time");
      if (!utc) continue;
      const d = new Date(utc + (utc.endsWith("Z") ? "" : "Z"));
      if (isNaN(d.getTime())) continue;
      const fmt = el.getAttribute("data-format") ?? "short";
      if (fmt === "full") {
        el.textContent = format(d, "d 'de' MMMM 'a las' HH:mm", { locale: es });
      } else {
        el.textContent = format(d, "d MMM HH:mm", { locale: es });
      }
    }
  });
</script>
