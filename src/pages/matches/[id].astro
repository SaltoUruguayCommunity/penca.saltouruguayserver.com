---
import { eq } from "drizzle-orm";
import Layout from "../../layouts/Layout.astro";
import MatchDetailView from "../../components/pencas/MatchDetailView.tsx";
import { client } from "../../db";
import {
  WcMatchesTable,
  WcPredictionsTable,
  UsersTable,
} from "../../db/schema";

const { id } = Astro.params;
if (!id || isNaN(Number(id))) {
  return Astro.redirect("/", 302);
}

const matchId = Number(id);

const match = await client.query.WcMatchesTable.findFirst({
  where: eq(WcMatchesTable.id, matchId),
  with: {
    homeTeam: { columns: { id: true, name: true, flag: true, fifaCode: true } },
    awayTeam: { columns: { id: true, name: true, flag: true, fifaCode: true } },
    group: { columns: { id: true, name: true } },
  },
});

if (!match) {
  return Astro.redirect("/", 302);
}

const allPredictions = await client
  .select({
    userId: WcPredictionsTable.userId,
    username: UsersTable.username,
    avatar: UsersTable.avatar,
    homeScore: WcPredictionsTable.homeScore,
    awayScore: WcPredictionsTable.awayScore,
    points: WcPredictionsTable.points,
  })
  .from(WcPredictionsTable)
  .innerJoin(UsersTable, eq(WcPredictionsTable.userId, UsersTable.id))
  .where(eq(WcPredictionsTable.matchId, matchId))
  .all();

const { user } = Astro.locals;

const userPrediction = user?.id
  ? (allPredictions.find((p) => p.userId === user.id) ?? null)
  : null;

let userStreak = 0;
if (user?.id) {
  const userData = await client.query.UsersTable.findFirst({
    where: eq(UsersTable.id, Number(user.id)),
    columns: { streak: true },
  });
  userStreak = userData?.streak ?? 0;
}

const matchDetail = {
  id: match.id,
  matchDate: match.matchDate,
  stage: match.stage,
  status: match.status,
  homeScore: match.homeScore,
  awayScore: match.awayScore,
  homeTeam: match.homeTeam,
  awayTeam: match.awayTeam,
  group: match.group,
};

const STAGE_LABELS: Record<string, string> = {
  group: "Fase de Grupos",
  last_32: "Treintaydosavos",
  last_16: "Dieciseisavos",
  round_of_16: "Dieciseisavos",
  quarter_final: "Cuartos",
  semi_final: "Semifinal",
  third_place: "Tercer Puesto",
  final: "Final",
};

const matchDate = new Date(match.matchDate);
const isFinished = match.status === "finished";
const isLive = !isFinished && matchDate <= new Date();

const eventStatusMap: Record<string, string> = {
  scheduled: "https://schema.org/EventScheduled",
  live: "https://schema.org/EventActive",
  finished: "https://schema.org/EventCompleted",
  postponed: "https://schema.org/EventPostponed",
  cancelled: "https://schema.org/EventCancelled",
};

const homeCompetitor: Record<string, unknown> = {
  "@type": "SportsTeam",
  "name": match.homeTeam.name,
};
if (match.homeTeam.flag) {
  homeCompetitor.image = match.homeTeam.flag;
}
if (match.homeTeam.fifaCode) {
  homeCompetitor.identifier = {
    "@type": "PropertyValue",
    "propertyID": "FIFA",
    value: match.homeTeam.fifaCode,
  };
}
if (match.homeScore !== null) {
  homeCompetitor.score = match.homeScore;
}

const awayCompetitor: Record<string, unknown> = {
  "@type": "SportsTeam",
  "name": match.awayTeam.name,
};
if (match.awayTeam.flag) {
  awayCompetitor.image = match.awayTeam.flag;
}
if (match.awayTeam.fifaCode) {
  awayCompetitor.identifier = {
    "@type": "PropertyValue",
    "propertyID": "FIFA",
    value: match.awayTeam.fifaCode,
  };
}
if (match.awayScore !== null) {
  awayCompetitor.score = match.awayScore;
}

const sportsEventSchema = {
  "@context": "https://schema.org",
  "@type": "SportsEvent",
  "@id": `${Astro.url.origin}/matches/${match.id}#event`,
  "name": `${match.homeTeam.name} vs ${match.awayTeam.name}`,
  "description": `Partido de ${STAGE_LABELS[match.stage] ?? match.stage} del Mundial 2026 entre ${match.homeTeam.name} y ${match.awayTeam.name}.`,
  "startDate": match.matchDate,
  "eventStatus": eventStatusMap[match.status] ?? "https://schema.org/EventScheduled",
  "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
  "location": {
    "@type": "Place",
    "name": "Estadio del Mundial 2026",
    "address": { "@type": "PostalAddress", "addressCountry": "US" },
  },
  "competitor": [homeCompetitor, awayCompetitor],
  "superEvent": {
    "@type": "SportsEvent",
    "name": "FIFA World Cup 2026",
  },
  "organizer": { "@id": "https://saltouruguayserver.com/#organization" },
};
---

<Layout
  title={`${match.homeTeam.name} vs ${match.awayTeam.name}`}
  description={`Pronóstico del partido ${match.homeTeam.name} vs ${match.awayTeam.name} por ${STAGE_LABELS[match.stage] ?? match.stage} del Mundial 2026.`}
  image={match.homeTeam.flag ?? match.awayTeam.flag ?? undefined}
>
  <script type="application/ld+json" set:html={JSON.stringify(sportsEventSchema)}></script>
  <div class="min-h-screen">
    <!-- Ambient Background -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
      <div
        class="bokeh-dot w-[500px] h-[500px] bg-accent/10 top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2"
      >
      </div>
      <div
        class="bokeh-dot w-[300px] h-[300px] bg-gold/5 bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2"
      >
      </div>
      <div
        class="absolute inset-0"
        style="background: repeating-linear-gradient(0deg, transparent, transparent 1px, rgba(255,255,255,0.015) 1px, rgba(255,255,255,0.015) 2px), repeating-linear-gradient(90deg, transparent, transparent 1px, rgba(255,255,255,0.015) 1px, rgba(255,255,255,0.015) 2px);"
      >
      </div>
    </div>

    <nav
      id="navbar"
      class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-xl border-b border-accent-border/30 transition-shadow duration-300"
    >
      <div
        class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16"
      >
        <a
          href="/"
          class="flex items-center gap-x-4 font-barlow font-black tracking-tight group"
        >
          <img
            src="/images/logo_salto.webp"
            alt="SaltoUruguayServer"
            class="h-10 w-auto object-contain transition-transform duration-300 group-hover:scale-110"
          />
          <div class="flex flex-col leading-none">
            <span class="text-2xl md:text-4xl"
              ><span class="text-white">LA </span><span class="text-accent"
                >PENCA</span
              ></span
            >
            <span
              class="text-[0.7rem] uppercase tracking-[0.2em] text-white/50 font-mono"
              >de SaltoUruguayServer</span
            >
          </div>
        </a>
        <div class="ml-auto flex items-center gap-3">
          <a
            href="/pronosticos"
            class="text-xs font-semibold uppercase tracking-wider text-muted hover:text-white transition font-teko group"
          >
            <span
              class="inline-block transition-transform duration-200 group-hover:-translate-x-1"
              >←</span
            > Volver
          </a>
        </div>
      </div>
    </nav>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
      <div class="glass-card p-6 sm:p-8 mb-6 glow-violet">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <span
              data-time={match.matchDate}
              data-format="full"
              class="text-sm text-muted font-semibold uppercase tracking-wider"
            ></span>
            <span
              class="text-xs text-muted/50 font-semibold uppercase tracking-wider"
            >
              {STAGE_LABELS[match.stage] ?? match.stage}
            </span>
          </div>
          <span
            class={`badge-pill ${
              isLive
                ? "!bg-green-accent/15 !text-green-accent"
                : isFinished
                  ? "!bg-zinc-800 !text-zinc-400"
                  : "!bg-accent/10 !text-accent-light"
            }`}
          >
            {isLive ? "EN VIVO" : isFinished ? "Finalizado" : "Programado"}
          </span>
        </div>

        {
          match.group && (
            <div class="text-xs text-muted/60 font-semibold uppercase tracking-wider mb-4">
              Grupo {match.group.name}
            </div>
          )
        }

        <div class="flex items-center justify-center gap-6 sm:gap-12 py-6">
          <div class="flex flex-col items-center gap-3 flex-1">
            {
              match.homeTeam.flag ? (
                <img
                  src={match.homeTeam.flag}
                  alt=""
                  class="h-16 w-16 sm:h-20 sm:w-20 object-contain"
                />
              ) : (
                <div class="h-16 w-16 rounded-full bg-zinc-800 flex items-center justify-center text-2xl">
                  ⚽
                </div>
              )
            }
            <span
              class="font-barlow font-bold text-lg sm:text-xl text-white text-center"
            >
              {match.homeTeam.name}
            </span>
          </div>

          <div class="flex flex-col items-center gap-2 shrink-0">
            {
              isFinished || isLive ? (
                <div class="flex items-center gap-4">
                  <span class="font-barlow font-black text-4xl sm:text-5xl text-white tabular-nums drop-shadow-[0_0_15px_rgba(139,92,246,0.15)]">
                    {match.homeScore ?? "-"}
                  </span>
                  <span class="text-accent/40 font-bold text-3xl">-</span>
                  <span class="font-barlow font-black text-4xl sm:text-5xl text-white tabular-nums drop-shadow-[0_0_15px_rgba(139,92,246,0.15)]">
                    {match.awayScore ?? "-"}
                  </span>
                </div>
              ) : (
                <div class="text-center">
                  <span class="font-barlow font-black text-3xl text-muted">
                    vs
                  </span>
                </div>
              )
            }
            {
              isFinished && (
                <div class="text-[11px] text-muted uppercase tracking-wider font-semibold">
                  {match.homeScore !== null && match.awayScore !== null
                    ? match.homeScore > match.awayScore
                      ? `Ganó ${match.homeTeam.name}`
                      : match.homeScore < match.awayScore
                        ? `Ganó ${match.awayTeam.name}`
                        : "Empate"
                    : ""}
                </div>
              )
            }
          </div>

          <div class="flex flex-col items-center gap-3 flex-1">
            {
              match.awayTeam.flag ? (
                <img
                  src={match.awayTeam.flag}
                  alt=""
                  class="h-16 w-16 sm:h-20 sm:w-20 object-contain"
                />
              ) : (
                <div class="h-16 w-16 rounded-full bg-zinc-800 flex items-center justify-center text-2xl">
                  ⚽
                </div>
              )
            }
            <span
              class="font-barlow font-bold text-lg sm:text-xl text-white text-center"
            >
              {match.awayTeam.name}
            </span>
          </div>
        </div>

        {
          userPrediction && isFinished && (
            <div class="mt-6 pt-4 border-t border-accent-border/20 text-center">
              <div class="inline-flex items-center gap-3 px-4 py-2 rounded-lg bg-accent-subtle/40">
                <span class="text-xs text-muted uppercase tracking-wider font-semibold">
                  Tu pronóstico:
                </span>
                <span class="font-barlow font-bold text-lg text-white tabular-nums">
                  {userPrediction.homeScore} - {userPrediction.awayScore}
                </span>
                <span
                  class={`badge-pill ${
                    userPrediction.points && userPrediction.points > 0
                      ? "!bg-green-accent/15 !text-green-accent"
                      : "!bg-zinc-800 !text-zinc-500"
                  }`}
                >
                  {userPrediction.points != null
                    ? `${userPrediction.points} pts`
                    : "Pendiente"}
                </span>
              </div>
            </div>
          )
        }
      </div>

      <MatchDetailView
        client:load
        match={matchDetail}
        predictions={allPredictions}
        userPrediction={userPrediction}
        userStreak={userStreak}
        user={user}
      />
    </div>

    <!-- Footer -->
    <footer
      class="relative border-t border-white/10 bg-[#050505] py-10 overflow-hidden"
    >
      <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[200px] rounded-full pointer-events-none"
        style="background: rgba(139,92,246,0.05); filter: blur(80px);"
      >
      </div>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div
          class="flex flex-col md:flex-row items-center justify-between gap-6"
        >
          <a
            href="/"
            class="flex items-center gap-2 font-barlow font-black text-lg group"
          >
            <span
              class="text-accent transition-transform duration-300 group-hover:scale-110"
              >⚽</span
            >
            <span class="text-white">LA</span>
            <span class="text-accent">PENCA</span>
          </a>
          <div class="flex items-center gap-6">
            <a
              href="https://instagram.com/saltouruguayserver"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/40 hover:text-accent transition text-xs uppercase tracking-wider"
              >Instagram</a
            >
            <a
              href="https://discord.gg/XwHSRRwnzS"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/40 hover:text-accent transition text-xs uppercase tracking-wider"
              >Discord</a
            >
            <a
              href="https://twitch.tv/saltouruguayserver"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/40 hover:text-accent transition text-xs uppercase tracking-wider"
              >Twitch</a
            >
          </div>
          <p class="text-white/30 text-xs font-mono">
            &copy; {new Date().getFullYear()} Desarrollado por <a
              href="https://instagram.com/alexitoo_uy"
              target="_blank"
              rel="noopener noreferrer"
              class="text-white/60 hover:text-accent transition">Alexitoo_UY</a
            >
          </p>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<script>
  const navbar = document.getElementById("navbar")!;
  let ticking = false;
  document.addEventListener("scroll", () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        if (window.scrollY > 20) {
          navbar.style.boxShadow = "0 4px 30px rgba(139, 92, 246, 0.1)";
        } else {
          navbar.style.boxShadow = "none";
        }
        ticking = false;
      });
      ticking = true;
    }
  });
</script>
