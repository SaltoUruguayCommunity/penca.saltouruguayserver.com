---
import { getSession } from "auth-astro/server";
import Layout from "../layouts/Layout.astro";

const session = await getSession(Astro.request);

if (session?.user) {
  return Astro.redirect("/pronosticos", 302);
}
---

<Layout title="Penca Mundial 2026">
  <!-- ===== NAV ===== -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-surface/80 backdrop-blur-lg border-b border-accent-border/30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 font-barlow font-black text-xl tracking-tight">
        <span class="text-accent">⚽</span>
        <span class="text-white">LA</span>
        <span class="text-accent">PENCA</span>
      </a>

      <div class="hidden md:flex items-center gap-8">
        <a href="#como-funciona" class="text-xs font-semibold uppercase tracking-[0.12em] text-muted hover:text-white transition font-teko">Como funciona</a>
        <a href="#puntuacion" class="text-xs font-semibold uppercase tracking-[0.12em] text-muted hover:text-white transition font-teko">Puntuacion</a>
      </div>

      <button data-popup-login class="btn-primary !py-2 !px-4 !text-xs cursor-pointer">Ingresar</button>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <section class="relative min-h-screen flex items-center overflow-hidden pt-16">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="bokeh-dot w-[500px] h-[500px] bg-accent/10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2" />
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        <div class="flex-1 text-center lg:text-left">
          <div class="inline-flex items-center gap-2 badge-pill mb-5">
            <span class="w-1.5 h-1.5 rounded-full bg-green-accent animate-pulse" />
            de <span class="text-white/80">SaltoUruguayServer</span>
          </div>

          <h1 class="font-barlow font-black italic uppercase leading-[0.85]">
            <span class="text-[clamp(2.5rem,8vw,6rem)] block text-white">PRONOSTICA</span>
            <span class="text-[clamp(2rem,7vw,5rem)] block text-accent">CADA PARTIDO</span>
            <span class="text-[clamp(2rem,7vw,5rem)] block text-white">DEL MUNDIAL</span>
          </h1>

          <p class="mt-5 text-muted text-base max-w-lg mx-auto lg:mx-0 leading-relaxed">
            Competi contra otros hinchas, acumula puntos y subi en el ranking.
            Demostra quien sabe mas de futbol.
          </p>

          <div class="mt-8 flex flex-wrap gap-4 justify-center lg:justify-start">
            <a href="/pronosticos" class="btn-primary">
              Empezar ahora
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <button data-popup-login class="btn-secondary cursor-pointer">Ingresar</button>
          </div>
        </div>

        <div class="shrink-0 flex flex-col items-center gap-4">
          <div class="relative">
            <div class="text-[100px] sm:text-[140px] leading-none drop-shadow-[0_0_40px_rgba(250,204,21,0.25)]">
              🏆
            </div>
            <div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-32 h-32 bg-gold/15 rounded-full blur-[50px]" />
          </div>

          <div class="flex gap-8">
            <div class="text-center">
              <div class="font-barlow font-black text-2xl text-gold">32</div>
              <div class="text-xs uppercase tracking-[0.12em] text-muted mt-0.5">Selecciones</div>
            </div>
            <div class="text-center">
              <div class="font-barlow font-black text-2xl text-gold">64</div>
              <div class="text-xs uppercase tracking-[0.12em] text-muted mt-0.5">Partidos</div>
            </div>
            <div class="text-center">
              <div class="font-barlow font-black text-2xl text-accent">★</div>
              <div class="text-xs uppercase tracking-[0.12em] text-muted mt-0.5">Premios</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="como-funciona" class="py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-barlow font-bold uppercase text-[clamp(1.5rem,4vw,2.25rem)] text-white text-center mb-12">
        Como funciona
      </h2>

      <div class="grid md:grid-cols-3 gap-5">
        {[
          { icon: "🎯", title: "Elegi tus pronosticos", desc: "Antes de cada partido, ingresa el resultado que crees. Tienes hasta el pitido inicial." },
          { icon: "📊", title: "Segui los resultados", desc: "Los puntajes se actualizan solos cuando termina cada partido. Cada acierto suma." },
          { icon: "🏆", title: "Subi en el ranking", desc: "Competi contra todos los hinchas. Mientras mas aciertos, mas alto subis." },
        ].map(({ icon, title, desc }) => (
          <div class="glass-card p-6 text-center group hover:border-accent/40 transition duration-300">
            <div class="w-14 h-14 mx-auto mb-4 rounded-xl border border-accent bg-accent-subtle flex items-center justify-center text-2xl group-hover:border-accent/60 group-hover:shadow-[0_0_20px_rgba(139,92,246,0.15)] transition-all duration-300">
              {icon}
            </div>
            <h3 class="font-barlow font-bold uppercase text-base text-white mb-2">{title}</h3>
            <p class="text-muted text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SCORING ===== -->
  <section id="puntuacion" class="pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-barlow font-bold uppercase text-[clamp(1.5rem,4vw,2.25rem)] text-white text-center mb-8">
        Puntuacion
      </h2>

      <div class="glass-card p-6 sm:p-8">
        <div class="flex flex-col sm:flex-row gap-4 sm:gap-6">
          <div class="flex-1 flex items-center gap-4 p-4 rounded-lg bg-green-accent/5 border border-green-accent/15">
            <div class="w-12 h-12 rounded-full bg-green-accent/10 border-2 border-green-accent/30 flex items-center justify-center shrink-0">
              <span class="font-barlow font-black text-xl text-green-accent">5</span>
            </div>
            <div>
              <p class="font-barlow font-bold uppercase text-sm text-white">Exacto</p>
              <p class="text-muted text-xs">Marcador exacto</p>
            </div>
          </div>
          <div class="flex-1 flex items-center gap-4 p-4 rounded-lg bg-accent/5 border border-accent/15">
            <div class="w-12 h-12 rounded-full bg-accent/10 border-2 border-accent/30 flex items-center justify-center shrink-0">
              <span class="font-barlow font-black text-xl text-accent">2</span>
            </div>
            <div>
              <p class="font-barlow font-bold uppercase text-sm text-white">Ganador</p>
              <p class="text-muted text-xs">Ganador correcto</p>
            </div>
          </div>
          <div class="flex-1 flex items-center gap-4 p-4 rounded-lg bg-zinc-800/30 border border-zinc-700/30">
            <div class="w-12 h-12 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center shrink-0">
              <span class="font-barlow font-black text-xl text-zinc-500">0</span>
            </div>
            <div>
              <p class="font-barlow font-bold uppercase text-sm text-white">Nada</p>
              <p class="text-muted text-xs">Sin acierto</p>
            </div>
          </div>
        </div>
        <p class="text-center text-muted text-xs mt-5">
          ★ Bonus: cada pronostico da <span class="text-green-accent font-semibold">1 moneda</span>, resultado exacto da <span class="text-gold font-semibold">5 monedas extra</span>
        </p>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="pb-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-gradient-to-br from-accent-deep via-accent to-accent-deep p-10 sm:p-14 text-center relative overflow-hidden">
        <div class="absolute -top-8 -right-8 text-white/5 text-[120px] font-barlow font-black italic leading-none select-none">★</div>
        <div class="relative">
          <div class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.15em] text-white/60 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-gold animate-pulse" />
            SaltoUruguayServer
          </div>
          <h2 class="font-barlow font-black italic uppercase text-[clamp(2rem,5vw,3.5rem)] text-white leading-[0.9] mb-3">
            ¡Que empiece<br />la Penca!
          </h2>
          <p class="text-white/70 text-sm max-w-md mx-auto mb-6">
            Cada partido es una oportunidad para sumar puntos. No te quedes afuera.
          </p>
          <div class="flex flex-wrap gap-3 justify-center">
            <a href="/pronosticos" class="btn-primary !bg-white !text-accent-deep hover:!bg-white/90">
              Empezar a pronosticar
            </a>
            <button data-popup-login class="inline-flex items-center gap-2 px-5 py-3 border border-white/30 rounded-md text-white font-barlow font-bold uppercase text-sm hover:bg-white/10 transition cursor-pointer">
              Ingresar
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="border-t border-accent-border/20 py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <a href="/" class="flex items-center gap-2 font-barlow font-black text-lg">
          <span class="text-accent">⚽</span>
          <span class="text-white">LA</span>
          <span class="text-accent">PENCA</span>
        </a>
        <div class="flex items-center gap-6">
          <a href="#como-funciona" class="text-muted text-xs hover:text-accent transition uppercase tracking-wider font-semibold font-teko">Como funciona</a>
          <a href="#puntuacion" class="text-muted text-xs hover:text-accent transition uppercase tracking-wider font-semibold font-teko">Puntuacion</a>
          <a href="https://saltouruguayserver.com" class="text-muted text-xs hover:text-accent transition uppercase tracking-wider font-semibold font-teko">SaltoUruguayServer</a>
        </div>
        <div class="flex gap-3">
          <a href="https://saltouruguayserver.com" class="w-9 h-9 rounded-lg border border-accent-border/20 flex items-center justify-center text-muted hover:text-accent hover:border-accent/40 transition" title="SaltoUruguayServer">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.879v-6.99h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.99C18.343 21.128 22 16.991 22 12c0-5.523-4.477-10-10-10z"/></svg>
          </a>
          <a href="https://saltouruguayserver.com/discord" class="w-9 h-9 rounded-lg border border-accent-border/20 flex items-center justify-center text-muted hover:text-accent hover:border-accent/40 transition" title="Discord">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/></svg>
          </a>
        </div>
      </div>
      <div class="divider-violet mt-8 mb-4" />
      <p class="text-center text-muted text-xs">&copy; {new Date().getFullYear()} <a href="https://saltouruguayserver.com" class="hover:text-accent transition">SaltoUruguayServer</a> &mdash; <a href="https://penca.saltouruguayserver.com" class="hover:text-accent transition">penca.saltouruguayserver.com</a></p>
    </div>
  </footer>

  <!-- ===== POPUP LOGIN SCRIPT ===== -->
  <script>
    document.addEventListener("click", (e) => {
      const loginBtn = e.target.closest("[data-popup-login]");
      if (loginBtn) {
        e.preventDefault();
        const width = 580;
        const height = 680;
        const left = window.innerWidth / 2 - width / 2;
        const top = window.innerHeight / 2 - height / 2;

        window.open(
          "/auth/sus",
          "Iniciar sesion",
          `toolbar=no,location=no,directories=no,status=no,menubar=no,scrollbars=no,resizable=no,copyhistory=no,width=${width},height=${height},top=${top},left=${left}`,
        );

        window.addEventListener("SignInError", () => {}, { once: true });
      }
    });
  </script>
</Layout>
